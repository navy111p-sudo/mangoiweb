# 서버 설정
PORT=3000

# TURN 중계 서버 URL (Cloudflare Workers 배포 후 설정)
TURN_RELAY_URL=

# 방 설정
MAX_ROOM_SIZE=10
SIGNALING_MAX_PEERS=2

# ── Cloudflare TURN (운영용 동적 자격증명) ──
# Cloudflare 대시보드 > Realtime > TURN 에서 키 생성 후 입력.
# 둘 다 비어 있으면 개발용 공개 TURN 으로 자동 폴백한다.
# ⚠️ TURN_KEY_API_TOKEN 은 비밀키이므로 절대 클라이언트/깃에 노출 금지.
TURN_KEY_ID=
TURN_KEY_API_TOKEN=
# 자격증명 유효시간(초). 기본 86400(24시간).
TURN_TTL=86400
