# ============================================================================
#  app/.env.example — FastAPI 백엔드(app/) 환경변수 예시
# ----------------------------------------------------------------------------
#  (루트의 .env.example 은 Workers/TURN 인프라용이라 별개입니다. 이 파일이 백엔드용.)
#
#  로컬 실행:  이 파일을 복사해 .env 로 만들고 값 입력 →
#              (PowerShell)  $env:OPENAI_API_KEY="sk-..."; uvicorn app.main:app --reload --port 8010
#  배포 시:    Render/Railway 대시보드의 "Environment/Variables" 에 같은 키로 입력.
#  ⚠️ 실제 키가 든 .env 는 절대 깃에 커밋하지 마세요(.dockerignore 로 이미지에서도 제외됨).
# ============================================================================

# 🔑 [필수] OpenAI API 키 — AI 웜업 대화에 사용
#    https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-your-openai-key-here

# 🤖 [선택] 웜업에 사용할 OpenAI 모델(기본: gpt-4o-mini)
# OPENAI_WARMUP_MODEL=gpt-4o-mini

# 🗄️ [선택] 데이터베이스 주소
#    - 비워두면 로컬 SQLite(app/mangoi_backend.db) 사용 → 간단하지만 재배포 시 초기화됨.
#    - 프로덕션에서는 Postgres 권장(영구 저장). 예시:
#        postgresql://USER:PASSWORD@HOST:5432/DBNAME
#    - 호스팅사가 'postgres://...' 형식을 줘도 코드가 자동으로 'postgresql://' 로 바꿔줍니다.
# DATABASE_URL=postgresql://user:password@localhost:5432/mangoi

# 🌐 [선택] CORS 허용 오리진(콤마로 구분). 미설정 시 망고아이 기본 도메인 허용.
#    모두 허용(개발용): CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_ORIGINS=https://test.mangoi.co.kr,https://mangoi.co.kr

# 🔌 [선택] 포트 — Render/Railway 는 $PORT 를 자동 주입하므로 보통 불필요.
# PORT=8010
